# ---------- Core server configuration ----------

# Primary Postgres connection string (Neon or equivalent). Required for sessions and daily challenge.
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Express server port
PORT=8080

# Required to sign session cookies – replace before deploying. Required in production.
SESSION_SECRET="dev-session-secret-change-me"

# Daily challenge rotation (timezone and hour for rolling the daily word)
DAILY_TZ="America/New_York"
DAILY_ROLL_HOUR=0

# ---------- Word lists (optional; defaults to server/words.txt and server/allowed_guesses.txt) ----------

# WORDLIST_PATH="./words.txt"
# GUESSES_PATH="./allowed_guesses.txt"

# ---------- Game tuning (optional) ----------

# Duel mode round duration in milliseconds (default: 6 minutes)
# DUEL_ROUND_MS=360000

# ---------- OAuth / OpenID Connect ----------

# Identity provider discovery endpoint (Replit OIDC by default; use https://accounts.google.com for Google)
ISSUER_URL="https://replit.com/oidc"

# Public origin for the frontend app (no trailing slash). Used for redirects and CORS base.
BASE_URL="http://localhost:5000"

# OAuth client credentials (Google Cloud console or Replit)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Replit-compatible client ID (often same as GOOGLE_CLIENT_ID)
REPL_ID="your-replit-client-id.apps.googleusercontent.com"

# Domains the backend should trust for login/callback (host[:port]). Required for auth in deployment.
REPLIT_DOMAINS="localhost:8080"

# Replit dev domain (set automatically on Replit; optional elsewhere)
# REPLIT_DEV_DOMAIN=""

# ---------- CORS ----------

# Comma-separated list of exact origins that may use cookies with the API
CORS_ALLOWED_ORIGINS="http://localhost:5000"

# Optional list of hostname suffixes (e.g. Vercel previews) also allowed
CORS_ALLOWED_ORIGIN_SUFFIXES=".vercel.app"

# ---------- Session cookie overrides (optional) ----------

# SameSite defaults to "none" when NODE_ENV=production; override if needed
# SESSION_COOKIE_SAME_SITE="none"

# Leave unset unless you need to share cookies across subdomains
# SESSION_COOKIE_DOMAIN=".example.com"

# ---------- Client (Vite) ----------

# Point the frontend at the backend origin. Set in client/.env or root .env for Vite.
VITE_SERVER_URL="http://localhost:8080"

# ---------- Testing (optional) ----------

# Set to "true" to skip OAuth/session setup (e.g. in CI or health checks)
# SKIP_AUTH_SETUP="true"

# ---------- Battle AI event (optional) ----------

# Set to "true" to enable scheduled AI Battle event
# AI_BATTLE_EVENT_ACTIVE="false"
# Time window for the event (default 20:00-21:00)
# AI_BATTLE_EVENT_SLOT="20:00-21:00"

# ---------- Admin / events (optional) ----------

# Token for event admin API (server/admin/events.js)
# EVENT_ADMIN_TOKEN=""

# ---------- Error tracking (optional) ----------

# Sentry DSN for client (Vite) – set in client/.env or root for Vite
# VITE_SENTRY_DSN=""
# Sentry DSN and environment for server
# SENTRY_DSN=""
# SENTRY_ENVIRONMENT="development"
